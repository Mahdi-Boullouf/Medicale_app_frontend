	<!-- ==================== PERMISSIONS FOR REELS FEATURE ==================== -->
	
	<!-- Photo Library Access (Gallery theke video select korar jonno) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>We need access to your photo library to select and upload medical reels and share images in chat</string>
	
	<!-- Photo Library Add Only (iOS 14+) -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>We need access to save videos and images to your photo library</string>
	
	<!-- ==================== VIDEO/AUDIO CALL PERMISSIONS ==================== -->
	
	<!-- Camera Access (Video call and reel recording er jonno) -->
	<key>NSCameraUsageDescription</key>
	<string>We need camera access for video calls with doctors and to record medical reels</string>
	
	<!-- Microphone Access (Audio/Video call er audio and reel audio er jonno) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>We need microphone access for audio and video calls with doctors, and to record audio for medical reels</string>
	
	<!-- Motion Usage (Optional - video recording er shomoy) -->
	<key>NSMotionUsageDescription</key>
	<string>We use motion data to enhance video recording quality</string>
	
	<!-- Local Network (Development er jonno - localhost API and WebRTC) -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>We need access to local network for API communication and real-time video/audio calls</string>
	
	<!-- ==================== NETWORK SECURITY SETTINGS ==================== -->
	
	<!-- App Transport Security Settings (HTTP API calls and WebRTC er jonno) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Allow all HTTP connections (Development only) -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		
		<!-- Allow local networking for WebRTC STUN/TURN servers -->
		<key>NSAllowsLocalNetworking</key>
		<true/>
		
